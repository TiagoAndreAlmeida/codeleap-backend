# --- Django Settings ---
# Set to 'False' in production
DEBUG=True
# Generate a secret key for your project
SECRET_KEY=django-insecure-your-secret-key-here
# Comma-separated list of allowed hosts (e.g., localhost,127.0.0.1,yourdomain.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database Settings ---
DB_NAME=codeleap_db
DB_USER=postgres
DB_PASSWORD=postgres
# Use 'codeleap-db' if running inside Docker, or 'localhost' if running locally
DB_HOST=codeleap-db
DB_PORT=5432

# --- CORS Settings ---
# Set to 'True' only for local development
CORS_ALLOW_ALL_ORIGINS=True
# In production, list your frontend URL (e.g., https://your-frontend.com)
# CORS_ALLOWED_ORIGINS=https://your-frontend.com

# --- Firebase Settings ---
# Ensure your firebase-service-account.json is in the project root
# This file name is already expected by the settings.py
